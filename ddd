        ChatSystem:SetConnectedText(Window.GlobalChatOptions.InitialStatusText)

        Window.AutoGlobalChat = {
            Page = GlobalChatTab,
            SubTab = SubTab,
            ChatSystem = ChatSystem
        }

        return ChatSystem
