                else
                    Items["Text"]:Tween(nil, {TextTransparency = 0.4})

                    if Page.Icon then
                        Items["Icon"]:ChangeItemTheme({ImageColor3 = "Text"})
                        Items["Icon"]:Tween(nil, {ImageColor3 = Library.Theme.Text, ImageTransparency = 0.4})
