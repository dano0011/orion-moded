            function ChatSystem:ConnectBackend(Config)
                self:DisconnectBackend()

                for _, Child in Items["Messages"].Instance:GetChildren() do
                    if not Child:IsA("UIListLayout") and not Child:IsA("UIPadding") then
                        Child:Destroy()
