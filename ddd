                Page.Active = Bool
                Debounce = true 

                Items["Page"].Instance.Visible = Bool
                Items["Page"].Instance.Parent = not Bool and Library.UnusedHolder.Instance or Page.Window.Items["Content"].Instance
                
                if Page.Active then
                    Items["Text"]:Tween(nil, {TextTransparency = 0})

                    if Page.Icon then
